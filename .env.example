# =============================================================================
# GRACE HUB SERVICE — Variables de entorno
# =============================================================================
# Copiá este archivo como .env y completá los valores correspondientes.
# NUNCA comitees el .env real al repositorio.
# =============================================================================


# =============================================================================
# BASE DE DATOS — elegí UNA de las dos opciones (A o B), no ambas.
# Si DATABASE_URL está definida y no está vacía, tiene PRIORIDAD sobre las
# variables individuales. Si la dejás comentada o vacía, se usan las vars de
# la Opción B como fallback automático.
# =============================================================================

# -----------------------------------------------------------------------------
# OPCIÓN A — Connection String (recomendada para cloud: Supabase, Neon, etc.)
# -----------------------------------------------------------------------------
# Formato:
#   postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE[?sslmode=require]
#
# SSL:
#   Incluí ?sslmode=require al final de la URL si el proveedor lo requiere.
#   La mayoría de las bases de datos cloud (Supabase, Neon, Railway, etc.) lo
#   exigen. Sin este parámetro la conexión será rechazada por el servidor remoto.
#   Para conexiones locales (localhost) se omite el parámetro.
#
# Caracteres especiales en usuario o contraseña:
#   Si tu contraseña contiene caracteres como @, #, /, ?, :, &, =, + o espacios,
#   debés URL-encodearlos ANTES de insertarlos en la URL, de lo contrario el
#   parser los interpreta como parte de la estructura de la URL y falla.
#   Tabla de encoding más comunes:
#     @  →  %40       #  →  %23       %  →  %25
#     :  →  %3A       /  →  %2F       ?  →  %3F
#     &  →  %26       =  →  %3D       +  →  %2B
#     (espacio) → %20
#   Herramienta online para encodear: https://www.urlencoder.org
#   Node.js:  encodeURIComponent('tu_password')
#
# Ejemplos por proveedor:
#   Supabase (directa):   postgresql://postgres:[PASS]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require
#   Supabase (pooling):   postgresql://postgres.[PROJECT]:[PASS]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
#   Neon:                 postgresql://[USER]:[PASS]@[HOST].neon.tech/[DB]?sslmode=require
#   Railway:              postgresql://[USER]:[PASS]@[HOST].railway.app:5432/[DB]?sslmode=require
#   Local (sin SSL):      postgresql://postgres:mypassword@localhost:5432/gracehub
#
# DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# -----------------------------------------------------------------------------
# OPCIÓN B — Variables individuales (fallback / desarrollo local)
# -----------------------------------------------------------------------------
# Se usan automáticamente si DATABASE_URL no está definida o está vacía.
# SSL: poné DATABASE_SSL=true si el servidor de BD requiere conexión cifrada.
#      Para localhost en desarrollo local, dejalo en false.
#
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=yourpassword
DATABASE_NAME=gracehub
DATABASE_SSL=false


# =============================================================================
# APLICACIÓN
# =============================================================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000


# =============================================================================
# JWT — Autenticación
# =============================================================================
# JWT_SECRET: clave secreta para firmar tokens.
#   IMPORTANTE: usá un valor aleatorio largo y único en producción.
#   Nunca uses el valor de ejemplo en un entorno real.
#   Generá uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-in-production
#
# JWT_EXPIRES_IN: duración del token. Formato: número + unidad.
#   Ejemplos: 1d (1 día), 8h (8 horas), 30m (30 minutos), 3600 (segundos)
JWT_EXPIRES_IN=1d
